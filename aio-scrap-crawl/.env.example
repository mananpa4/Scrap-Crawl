# ============================================================================
# aio-scrap-crawl — centralized configuration (.env)
# Copy to ".env" and adjust. All variables are optional; sensible defaults
# are applied by packages/core/src/config.ts.
# ============================================================================

# --- General -----------------------------------------------------------------
# Default engine used by the CLI/API when none is given.
# One of: fetch | crawlee | firecrawl | katana | pyai | scrapling
AIO_DEFAULT_ENGINE=fetch

# Logging: debug | info | warn | error | silent
AIO_LOG_LEVEL=info
# Emit logs as JSON lines instead of pretty text (true/false)
AIO_LOG_JSON=false

# Default output directory for exports
AIO_OUTPUT_DIR=./output

# Default User-Agent used by the built-in fetch engine
AIO_USER_AGENT=aio-scrap-crawl/0.1 (+https://github.com/)

# --- Crawl defaults ----------------------------------------------------------
AIO_MAX_PAGES=50
AIO_MAX_DEPTH=2
AIO_CONCURRENCY=5
AIO_DELAY_MS=0
AIO_RESPECT_ROBOTS=true

# --- Engine: Firecrawl (AGPL-3.0, run as separate service) -------------------
# Base URL of a self-hosted or hosted Firecrawl API. Leave empty to disable.
FIRECRAWL_API_URL=
FIRECRAWL_API_KEY=

# --- Engine: Katana (Go binary, optional) ------------------------------------
# Path to the `katana` binary. Leave empty to auto-detect on PATH.
KATANA_BIN=

# --- Service: py-ai (Crawl4AI / Scrapling / ScrapeGraphAI / browser-use) -----
# Base URL of the Python AI microservice. Leave empty to disable AI engines.
# Hosts both the `pyai` (Crawl4AI) and `scrapling` (stealth/adaptive) engines.
PYAI_URL=http://127.0.0.1:8099

# --- Security: WipeDown sanitizer --------------------------------------------
# When true, untrusted page content is sanitized before being sent to any LLM.
AIO_SECURITY_SANITIZE=true
# Optional dedicated WipeDown endpoint (defaults to PYAI_URL if empty)
WIPEDOWN_URL=

# --- LLM providers (used by py-ai service) -----------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://127.0.0.1:11434
# Used by the AI-vision captcha solver (self-hosted alternative)
GEMINI_API_KEY=

# --- Captcha solving (@aio/captcha, served by py-ai) -------------------------
# Primary provider: 2Captcha commercial service. Needs a paid account + credits.
# Read server-side by services/py-ai; the `2captcha` provider degrades to
# unavailable until this is set. Use only on sites where you are authorized.
TWOCAPTCHA_API_KEY=
# Default captcha provider for the CLI: 2captcha | ai-vision
AIO_CAPTCHA_PROVIDER=2captcha

# --- Optional network egress: MasterDnsVPN (MIT, out-of-band) ----------------
# MasterDnsVPN is a DNS-tunnelling transport (not a scraper). It is NOT part of
# the AIO core. If you run its client, it exposes a local SOCKS5 proxy you can
# route crawls through to reach censored/geo-blocked targets. Run it separately
# (repos/MasterDnsVPN-main) and point a proxy at its SOCKS5 listener.
# Proxy wiring through the Crawlee engine is a documented TODO (see TODO.md).
# AIO_PROXY_URL=socks5://127.0.0.1:1080
