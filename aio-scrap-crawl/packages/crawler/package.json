{
  "name": "@aio/crawler",
  "version": "0.1.0",
  "description": "Scalable crawl engine for aio-scrap-crawl built on Crawlee (Apache-2.0): request queue, autoscaling, session pool, proxy rotation and fingerprinting.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aio/core": "workspace:*",
    "crawlee": "^3.13.0"
  }
}
